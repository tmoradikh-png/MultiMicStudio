# =====================================================================
# MultiMic Studio — PRODUCTION environment template
# =====================================================================
# Copy to a private `.env.production` (NEVER commit it) and fill in real values.
# Every value is read by app/config.py. Keep secrets in your host's secret store.
#
# Quick start (local production simulation) is wired in docker-compose.prod.yml,
# which sets these for you with LOCAL-ONLY demo values.
# ---------------------------------------------------------------------

# --- Core -------------------------------------------------------------
# PostgreSQL connection. Format:
#   postgresql+psycopg2://USER:PASSWORD@HOST:5432/DBNAME
# (SQLite default is for local dev only — use Postgres in production.)
DATABASE_URL=postgresql+psycopg2://multimic:CHANGE_ME@db:5432/multimic

# Auth signing secret. MUST be a fresh long random string (see runbook).
# e.g. `python -c "import secrets; print(secrets.token_urlsafe(48))"`
JWT_SECRET=CHANGE_ME_to_a_long_random_string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# --- Public addressing ------------------------------------------------
# The absolute HTTPS URL the API is reachable at. Used to build absolute,
# signed file links. Must be your real domain in production.
PUBLIC_BASE_URL=https://api.your-domain.com

# Comma-separated browser origins allowed by CORS (your web dashboard).
CORS_ORIGINS=https://app.your-domain.com

# --- Secure file URLs (enable in production) --------------------------
# Serves audio via a signature-checked, expiring route instead of an open
# static mount, so recordings are not world-enumerable.
FILE_URL_SIGNING=true
FILE_URL_TTL_SECONDS=3600
# Dedicated HMAC secret for file-link signatures (falls back to JWT_SECRET if
# blank, but a separate secret is recommended). NOTE: the canonical variable
# name is FILE_SIGNING_SECRET.
FILE_SIGNING_SECRET=CHANGE_ME_to_another_long_random_string

# --- Storage ----------------------------------------------------------
# "s3" for hosted (S3 / Cloudflare R2 / DO Spaces / MinIO). "local" only for dev.
STORAGE_BACKEND=s3
# Used only when STORAGE_BACKEND=local:
STORAGE_LOCAL_DIR=./storage

# --- S3 / object storage (when STORAGE_BACKEND=s3) --------------------
S3_BUCKET=multimic-recordings
S3_REGION=us-east-1
# Set for S3-COMPATIBLE providers (R2 / Spaces / MinIO). Leave blank for AWS S3.
#   Cloudflare R2: https://<accountid>.r2.cloudflarestorage.com
#   DO Spaces:     https://<region>.digitaloceanspaces.com
#   MinIO (local): http://minio:9000
S3_ENDPOINT_URL=
S3_ACCESS_KEY_ID=CHANGE_ME
S3_SECRET_ACCESS_KEY=CHANGE_ME
# Optional public/CDN base for objects. Blank => backend returns presigned GETs.
S3_PUBLIC_BASE_URL=

# --- Private-beta safety limits --------------------------------------
MAX_UPLOAD_BYTES=26214400
MAX_RECORDING_SECONDS=300
ALLOWED_AUDIO_EXTENSIONS=wav,m4a,mp3,aac,caf,ogg,oga,opus,webm,flac,mp4,3gp,amr
SESSION_EXPIRY_MINUTES=240
CLEANUP_TEMP_MAX_AGE_HOURS=24

# --- Transcription (optional) ----------------------------------------
TRANSCRIPTION_BACKEND=stub
WHISPER_MODEL=base

# --- Live Mode (keep OFF) --------------------------------------------
LIVE_MODE_ENABLED=false

# Copy to .env and adjust.

# Use SQLite for zero-setup MVP, or PostgreSQL for production-aligned dev.
# SQLite:     sqlite:///./multimic.db
# PostgreSQL: postgresql+psycopg2://user:password@localhost:5432/multimic
DATABASE_URL=sqlite:///./multimic.db

# JWT signing secret — CHANGE THIS in any real deployment.
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRE_MINUTES=10080

# Storage backend: "local" (MVP) or "s3" (later).
STORAGE_BACKEND=local
STORAGE_LOCAL_DIR=./storage

# --- Hosting / public addressing -------------------------------------------
# Absolute base URL the API is reachable at. When set, stored file URLs are
# returned as absolute links (so a real domain / CDN works). Leave blank for the
# MVP's relative "/files/..." behaviour.
# Example: https://api.multimic.app
PUBLIC_BASE_URL=

# --- Secure file URLs (opt-in; default off keeps the MVP unchanged) ---------
# When true, local files are served via a signature-checked route (not an open
# static mount) so hosted audio cannot be enumerated or fetched without a valid,
# time-limited link. S3 uses presigned URLs automatically.
FILE_URL_SIGNING=false
FILE_URL_TTL_SECONDS=3600
# Dedicated secret for link signatures; falls back to JWT_SECRET when blank.
FILE_SIGNING_SECRET=

# --- S3 / object storage (only used when STORAGE_BACKEND=s3) ----------------
# Works with AWS S3 and S3-compatible stores (Cloudflare R2, DO Spaces, MinIO).
S3_BUCKET=
S3_REGION=
S3_ENDPOINT_URL=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
# Public CDN/bucket base for objects; blank => presigned GET URLs are used.
S3_PUBLIC_BASE_URL=

# Transcription: "stub" (no model) or "faster-whisper".
TRANSCRIPTION_BACKEND=stub
WHISPER_MODEL=base

# --- Private-beta safety limits --------------------------------------------
# Per-upload size cap (bytes). Oversize uploads are rejected with 413. 0 = off.
MAX_UPLOAD_BYTES=26214400
# Per-recording duration cap (seconds). Over-long takes rejected with 413. 0 = off.
MAX_RECORDING_SECONDS=300
# Accepted upload extensions (comma-separated). Anything else is rejected (415).
ALLOWED_AUDIO_EXTENSIONS=wav,m4a,mp3,aac,caf,ogg,oga,opus,webm,flac,mp4,3gp,amr
# Open/inactive sessions older than this are expired for joining + closed by the
# cleanup job. Completed projects stay accessible to the owner. 0 = off.
SESSION_EXPIRY_MINUTES=240
# Cleanup job: failed uploads / abandoned empty sessions older than this are
# removed. Successful project outputs are never deleted.
CLEANUP_TEMP_MAX_AGE_HOURS=24

# --- Live Mode (FUTURE milestone; keep off) ---------------------------------
# Feature flag only. False = the offline record→upload→process→export product
# exactly as today. See docs/ARCHITECTURE_HOSTING_AND_LIVE_MODE.md.
LIVE_MODE_ENABLED=false

# CORS origins for the web dashboard / mobile dev.
CORS_ORIGINS=http://localhost:3000,http://localhost:19006
